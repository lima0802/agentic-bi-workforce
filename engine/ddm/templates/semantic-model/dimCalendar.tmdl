	column 'Start of month' =

			STARTOFMONTH (dimCalendar[Date])
		formatString: mmmm yyyy
		lineageTag: <UUID-col-StartOfMonth>
		summarizeBy: none

		variation Variation
			isDefault
			relationship: <REL-dimCalendar-StartOfMonth>
			defaultHierarchy: <LDT-StartOfMonth>.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	column 'New Date' = dimCalendar[Date]
		formatString: General Date
		lineageTag: <UUID-col-NewDate>
		summarizeBy: none

		variation Variation
			isDefault
			relationship: <REL-dimCalendar-NewDate>
			defaultHierarchy: <LDT-NewDate>.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	partition dimCalendar-<UUID-partition> = calculated
		mode: import
		source = ```
				ADDCOLUMNS (
				    CALENDAR(
				        DATE(YEAR(MIN(<FACT_TABLE>[<FACT_DATE_COLUMN>])),MONTH(MIN(<FACT_TABLE>[<FACT_DATE_COLUMN>])),DAY(MIN(<FACT_TABLE>[<FACT_DATE_COLUMN>]))),
				        DATE(YEAR(MAX(<FACT_TABLE>[<FACT_DATE_COLUMN>])),MONTH(MAX(<FACT_TABLE>[<FACT_DATE_COLUMN>])),DAY(MAX(<FACT_TABLE>[<FACT_DATE_COLUMN>])))),

				"DateKey", FORMAT([Date], "YYYYMMDD"),

				"Year", FORMAT([Date], "yyyy"),
				"Half", if(MONTH([Date])<=6,"H1","H2"),

				"MonthNo", MONTH([Date]),

				"Month", FORMAT([Date],"MMM"),

				"Day", FORMAT([Date], "DD"),

				"MonthDay", FORMAT([Date], "MM-DD"),

				"Quarter", FORMAT([Date],"\QQ"),

				"YearMonthYYYY", FORMAT([Date],"YYYY-MM"),
				"YearMonthYY", FORMAT([Date],"YY-MM"),
				"YearMonth (date format)", date(YEAR([date]),month([Date]),1),
				"YearWeek (date format)", [date]-WEEKDAY([Date],2)+1,
				"YearWeek (string format)", YEAR([date]-WEEKDAY([Date],2)+1)&"-"&format(WEEKNUM([date]-WEEKDAY([Date],2)+1,1),"00"),
				"WeekdayNo", WEEKDAY([Date],2), //1-Sun..Sat, 2-Mon..Sat

				"Weekday", FORMAT([Date],"ddd"),

				"WeekNo", WEEKNUM([Date], 2)-1,


				"Week", "W" & WEEKNUM([Date], 2)-1 )
				```

	annotation PBI_Id = <HEX32-dimCalendar>
