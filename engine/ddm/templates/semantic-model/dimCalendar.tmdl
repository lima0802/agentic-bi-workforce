table dimCalendar
	lineageTag: <UUID-dimCalendar>

	measure 'Last Fact Date' =

			CALCULATE (
			    MAX ( <FACT_TABLE>[<FACT_DATE_COLUMN>] ),
			    REMOVEFILTERS ( dimCalendar )
			)
		formatString: General Date
		lineageTag: <UUID-LastFactDate>

	measure 'Is Full Month' =

			VAR MonthEnd =
			    EOMONTH ( MAX ( dimCalendar[Date] ), 0 )
			RETURN
			    MonthEnd <= [Last Fact Date]
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: <UUID-IsFullMonth>

	measure 'Is Full Week' =

			VAR WeekStart =
			    MAX ( dimCalendar[YearWeek (date format)] )
			VAR WeekEnd =
			    WeekStart + 6
			RETURN
			    WeekEnd <= [Last Fact Date]
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: <UUID-IsFullWeek>

	column Date
		formatString: General Date
		lineageTag: <UUID-col-Date>
		summarizeBy: none
		isNameInferred
		sourceColumn: [Date]

		variation Variation
			isDefault
			relationship: <REL-dimCalendar-Date>
			defaultHierarchy: <LDT-Date>.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column Year
		dataType: int64
		formatString: 0
		lineageTag: <UUID-col-Year>
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Year]

		annotation SummarizationSetBy = Automatic

	column MonthNo
		formatString: 0
		lineageTag: <UUID-col-MonthNo>
		summarizeBy: none
		isNameInferred
		sourceColumn: [MonthNo]

		annotation SummarizationSetBy = User

	column Month
