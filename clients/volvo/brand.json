{
  "brand": "Volvo Centum",
  "colors": {
    "primary":    "#1C3F6E",
    "secondary":  "#4A7FC1",
    "accent":     "#C8D8E8",
    "background": "#FFFFFF",
    "surface":    "#F4F6F9",
    "text":       "#1A1A1A",
    "textMuted":  "#6B7280",
    "border":     "#D1D9E0",
    "success":    "#2E7D32",
    "warning":    "#E65100",
    "danger":     "#C62828"
  },
  "typography": {
    "fontFamily":  "Volvo Novum, Volvo Broad, Arial, sans-serif",
    "headingSize": 14,
    "bodySize":    11,
    "labelSize":   10,
    "kpiValueSize": 24,
    "kpiLabelSize": 11,
    "fontWeightHeading": "SemiBold",
    "fontWeightBody":    "Regular"
  },
  "assets": {
    "logoPath":      "assets/volvo-centum-logo.svg",
    "backgroundPage": "assets/volvo-centum-bg.png"
  },
  "canvas": {
    "width":       1280,
    "height":      1300,
    "gridColumns": 3,
    "gridRows":    3,
    "gutterPx":    12,
    "paddingPx":   24
  },
  "kpiCard": {
    "borderRadius": 4,
    "showTrend":    true,
    "trendColorUp": "#2E7D32",
    "trendColorDown": "#C62828"
  },
  "slicers": {
    "bmSlicer": {
      "style":       "dropdown",
      "multiSelect": false,
      "label":       "Business Metric"
    }
  },
  "theme": {
    "name":    "Volvo Centum",
    "version": "1.0.0"
  }
}
